PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/tnc
JWT_SECRET=change-me-in-production

# Driving ETA to pickup (Distance Matrix API, departure_time=now for traffic when available).
# Enable "Distance Matrix API" and billing on the GCP project.
GOOGLE_DISTANCE_MATRIX_API_KEY=
# Optional alias:
# GOOGLE_MAPS_SERVER_API_KEY=

# ETA logging to server console ([tnc:eta:*]). Set to 0 to disable.
# TNC_ETA_LOG=0
