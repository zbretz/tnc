PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/tnc
JWT_SECRET=change-me-in-production

# Dev-only: driver picker + POST /auth/dev/login (no password). Omit or set !=1 in production.
# TNC_DEV_AUTH=1
# Password for seeded demo drivers (driver1@tnc.local, …); default "dev".
# TNC_DEV_PASSWORD=dev

# Driving ETA to pickup (Distance Matrix API, departure_time=now for traffic when available).
# Enable "Distance Matrix API" and billing on the GCP project.
GOOGLE_DISTANCE_MATRIX_API_KEY=
# Optional alias:
# GOOGLE_MAPS_SERVER_API_KEY=
# Map polylines (Directions API). Falls back to DISTANCE_MATRIX / MAPS_SERVER key if unset.
# GOOGLE_DIRECTIONS_API_KEY=
# Directions request logging. Set to 0 to disable.
# TNC_DIRECTIONS_LOG=0

# ETA logging to server console ([tnc:eta:*]). Set to 0 to disable.
# TNC_ETA_LOG=0
