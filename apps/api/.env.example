PORT=3000

# Driver profile photos: presigned S3 PUT (see POST /auth/me/avatar-upload-url). Omit S3_AVATAR_BUCKET to fall back to data URLs in the driver app.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_AVATAR_BUCKET=
# Optional: CloudFront or custom origin (no trailing slash). If unset, URLs use https://{bucket}.s3.{region}.amazonaws.com/...
# S3_AVATAR_PUBLIC_BASE_URL=
# Bucket must allow s3:PutObject for your IAM principal on avatars/*; objects must be readable at publicUrl (e.g. bucket policy GetObject public for that prefix, or OAC + CloudFront).

# Optional: if unset, API defaults to mongodb://127.0.0.1:27017/tnc
# Local: mongodb://127.0.0.1:27017/tnc
# Atlas: paste from Cluster → Connect → Drivers (include db name path and encode password special chars)
MONGODB_URI=mongodb://127.0.0.1:27017/tnc
JWT_SECRET=change-me-in-production

# Stripe (saved cards + off-session fare charge when driver completes trip). Secret must start with sk_; publishable with pk_ (match EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY on rider).
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# When true and Stripe is configured, riders must have a saved default card to POST /trips. Use true/false.
# TNC_REQUIRE_PAYMENT_METHOD_TO_BOOK=false

# Phone OTP (optional pepper; defaults to JWT_SECRET)
# OTP_PEPPER=

# Twilio Programmable SMS for POST /auth/otp/start (driver + rider OTP).
# Use either TWILIO_PHONE_NUMBER (E.164) or TWILIO_MESSAGING_SERVICE_SID (recommended for US A2P / 10DLC).
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+15551234567
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxx
# Optional message; must include {code} or the 4-digit code is appended.
# TWILIO_OTP_MESSAGE=Your verification code: {code}
# Local dev without Twilio: set TNC_DEV_OTP_LOG=1 to print codes to the API console.
# TNC_DEV_OTP_LOG=1
# Production: refuse OTP start if Twilio is not configured (no silent skip).
# TNC_OTP_REQUIRE_TWILIO=1

# Dev-only: driver picker + POST /auth/dev/login (no password). Omit or set !=1 in production.
# TNC_DEV_AUTH=1
# Password for seeded demo drivers (driver1@tnc.local, …); default "dev".
# TNC_DEV_PASSWORD=dev

# Driving ETA to pickup (Distance Matrix API, departure_time=now for traffic when available).
# Enable "Distance Matrix API" and billing on the GCP project.
GOOGLE_DISTANCE_MATRIX_API_KEY=
# Optional alias:
# GOOGLE_MAPS_SERVER_API_KEY=
# Map polylines (Directions API). Falls back to DISTANCE_MATRIX / MAPS_SERVER key if unset.
# GOOGLE_DIRECTIONS_API_KEY=
# Directions request logging. Set to 0 to disable.
# TNC_DIRECTIONS_LOG=0

# ETA logging to server console ([tnc:eta:*]). Set to 0 to disable.
# TNC_ETA_LOG=0

# Fare estimate (Distance Matrix). Defaults: Kimball, White Barn, Old Town (Park City area).
# Optional JSON override: [{"id":"kimball","name":"Kimball","lat":40.72,"lng":-111.54},...]
# TNC_PRICING_ANCHORS=
# TNC_FARE_MIN_USD=15
# TNC_FARE_TRIP_ANCHOR_MIN_1=10
# TNC_FARE_TRIP_ANCHOR_MIN_2=22
# TNC_FARE_TRIP_USD_1=15
# TNC_FARE_TRIP_USD_2=30
# TNC_FARE_ANCHOR_FAR_MINUTES=5
# TNC_FARE_ANCHOR_USD_PER_EXCESS_MIN=1.25
# Fare breakdown logging to server console ([tnc:fare]). Set to 0 to disable.
# TNC_FARE_LOG=0
# Max rider tip (USD) for POST /trips/:id/rider-tip; also capped at 200% of fare when fare > 0.
# TNC_MAX_TIP_USD=500
