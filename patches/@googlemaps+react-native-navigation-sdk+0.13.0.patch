diff --git a/node_modules/@googlemaps/react-native-navigation-sdk/ios/react-native-navigation-sdk/NavEventDispatcher.m b/node_modules/@googlemaps/react-native-navigation-sdk/ios/react-native-navigation-sdk/NavEventDispatcher.m
index dbdb9a4..a4e85df 100644
--- a/node_modules/@googlemaps/react-native-navigation-sdk/ios/react-native-navigation-sdk/NavEventDispatcher.m
+++ b/node_modules/@googlemaps/react-native-navigation-sdk/ios/react-native-navigation-sdk/NavEventDispatcher.m
@@ -66,11 +66,12 @@ RCT_EXPORT_MODULE(NavEventDispatcher);
 }
 
 - (void)sendEventName:(NSString *)eventName body:(id)body {
-  if (hasListeners) {
-    [self sendEventWithName:eventName body:body];
-  } else {
-    NSLog(@"NavEventDispatcher sendEventName called without listeners: %@", eventName);
+  // RN New Architecture: startObserving/hasListeners can lag behind JS addListener, dropping events
+  // (e.g. onNavigationReady) so navigation never proceeds. Always emit; JS ignores if unsubscribed.
+  if (!hasListeners) {
+    NSLog(@"NavEventDispatcher sendEventName (no native hasListeners flag yet): %@", eventName);
   }
+  [self sendEventWithName:eventName body:body];
 }
 
 @end
