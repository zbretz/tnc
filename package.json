{
  "name": "tnc",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "react-native-worklets": "0.5.1",
    "react-native-reanimated": {
      "react-native-worklets": "0.5.1"
    }
  },
  "dependencies": {
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "dotenv": "^16.4.5"
  },
  "scripts": {
    "dev:api": "npm run dev -w @tnc/api",
    "dev:rider": "npx expo start apps/rider --go",
    "dev:driver": "npx expo start apps/driver --go",
    "start": "npx expo start apps/rider --go"
  }
}
