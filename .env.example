# =============================================================================
# Monorepo root `.env` (this file lives at repo root: tnc/.env)
# =============================================================================
# Rider and driver both load THIS file only: apps/rider/app.config.js and
# apps/driver/app.config.js call dotenv with path ../../.env — not apps/rider/.env
# or apps/driver/.env.
#
# EAS / push (expo-notifications):
#   EXPO_PUBLIC_EAS_PROJECT_ID         — rider app (optional if app.config.js default is set)
#   EXPO_PUBLIC_EAS_PROJECT_ID_DRIVER  — driver app (optional if app.config.js default is set)
# If DRIVER is unset, driver falls back to EXPO_PUBLIC_EAS_PROJECT_ID (same Expo project as rider — not recommended for production push isolation).
# =============================================================================

# Used by Expo apps (rider + driver) via app.config.js — base URL for the Express API.
# Physical device: set to your computer's LAN IP, e.g. http://192.168.1.42:3000
# Android emulator: http://10.0.2.2:3000
# iOS Simulator: http://localhost:3000 is fine
EXPO_PUBLIC_API_URL=http://10.0.0.135:3000

# Rider: Stripe publishable key for @stripe/stripe-react-native (Payment Sheet). Should match API STRIPE_PUBLISHABLE_KEY.
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
#
# API Stripe secrets live in apps/api/.env (STRIPE_SECRET_KEY, STRIPE_PUBLISHABLE_KEY) — see apps/api/.env.example.

# EAS project IDs (expo-notifications, EAS Build). Defaults are also committed in each app’s app.config.js.
# Rider:  https://expo.dev/accounts/zbretz/projects/tnc-rider
# EXPO_PUBLIC_EAS_PROJECT_ID=f9b2e30e-7fa3-49f1-8719-2754efa9aa09
# Driver: https://expo.dev/accounts/zbretz/projects/tnc-driver
# EXPO_PUBLIC_EAS_PROJECT_ID_DRIVER=b65f0b10-6fe0-45c9-b20a-2ecf67ab170c

# Optional: required for dev builds / prebuild with Google Maps tiles (Maps SDK for iOS & Android).
# GOOGLE_MAPS_API_KEY=
